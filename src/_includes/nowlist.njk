{# This is a list of nowcontent - i.e., the page under "now"#}
{% extends "page.njk" %}
  {% block content %}
    <h1>
      <span class="big_text">{{ title }}</span>
      <br>
      <span class="subtitle"> {{subtitle}}</span> 
    </h1>

    {% if nowlist %}
    <p> list starts here - remove me </p>
    <div class="pagelist flow_s flow">
      {%- for post in nowlist -%}
        {% include "partials/nowpreview.njk" %}
      {%- endfor -%}
    </div>
    {% endif %}

    {% if pagination.href.previous or pagination.href.next %}
    <nav class="post_nav">
      
      {% if pagination.href.previous %}
        <div class="post_preview_nav_container">
          {% if page.url != pagination.href.first %}
            <a href="{{ pagination.href.first }}"><img class="control_icon" src="/images/structural/First.svg" alt="first page" width="40" height="40"></a>
          {% endif %}
          <a href="{{ pagination.href.previous }}"><img class="control_icon" src="/images/structural/Previous.svg" alt="previous page" width="40" height="40"></a>
        </div>
      {% endif %}
      <div></div>
      {% if pagination.href.next %}
        <div class="post_preview_nav_container">
          <a href="{{ pagination.href.next }}"><img class="control_icon" src="/images/structural/Next.svg" alt="next page" width="40" height="40"></a>
          {% if page.url != pagination.href.last %}
            <a href="{{ pagination.href.last }}"><img class="control_icon" src="/images/structural/Last.svg" alt="last page" width="40" height="40"></a>
          {% endif %}
        </div>
      {% endif %}

    </nav>
  {% endif %}
{% endblock %}