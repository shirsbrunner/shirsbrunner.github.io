{#Based on the infopages - this is the now page with additional info#}

{% extends "page.njk" %}

{% block content %}

  <h1>
    <span class="big_text">{{ title }}</span>
    <br>
    <span class="subtitle"> {{subtitle}}</span> 
  </h1>

        <div class="article_metrics">
        {% if date %}<p class="time">Last updated on: <time datetime="{{ date | dateymd }}">{{ date | datefriendly }}</time></p>{% endif %}
        </div>

  <div class="content_container">
    <div class="page_content flow">
      {{ content | safe }}
      <h2>Whut?</h2>
      <p>
      I'm glad you ask. This is a <a href="https://nownownow.com/about">now page</a>, and if you have your own site, maybe you should make one, too?
      </p>
      <p>
      This feels like a small thing to do, but maybe it isn't. I read a lot of people having problems updating now pages. Maybe you just don't feel like sharing some things with the world? Anyway, I'll give it a try and see what happens. 
      </p>
    </div>
  </div>

{% endblock %}